# Frontend environment variables
# Copy this file to .env.local and fill in your values

# NextAuth — generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# GitHub OAuth App — create one at https://github.com/settings/developers
# Set Homepage URL to http://localhost:3000
# Set Callback URL to http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Supabase — found in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL of the Python backend (change for production)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
