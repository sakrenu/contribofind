# Backend environment variables
# Copy this file to .env and fill in your values

# Groq API key — get one at https://console.groq.com
GROQ_API_KEY=

# Tavily API key — get one at https://app.tavily.com
TAVILY_API_KEY=

# Supabase project URL — found in your Supabase project settings
SUPABASE_URL=

# Supabase service role key — found in your Supabase project settings > API
# IMPORTANT: keep this secret — it bypasses Row Level Security
SUPABASE_SERVICE_ROLE_KEY=

# URL of the frontend (used for CORS)
FRONTEND_URL=http://localhost:3000
